# syntax=docker/dockerfile:1
ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.title="ghostwire-net" \
      org.opencontainers.image.description="Ghostwire - network recon, tunneling & traffic analysis" \
      org.opencontainers.image.vendor="ghostwire" \
      org.opencontainers.image.version="dev" \
      org.opencontainers.image.licenses="CC0-1.0"

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    LC_ALL=C.UTF-8 LANG=C.UTF-8 \
    PIP_NO_CACHE_DIR=1 \
    TERM=xterm-256color \
    ARTIFACTS=/shared \
    GHOST_LABEL=network \
    SOCKS5_HOST=127.0.0.1 \
    SOCKS5_PORT=1080

# ---- Core network toolchain ----
RUN set -eux; \
  apt-get update; \
  apt-get install -y --no-install-recommends \
    ca-certificates tzdata curl wget git jq sudo \
    nano less bash-completion \
    python3 python3-pip python3-venv \
    # scanners
    nmap masscan \
    # network basics
    dnsutils iputils-ping traceroute whois \
    netcat-openbsd socat openssl iproute2 tcpdump \
    # auth/brute
    hydra \
    # service enumeration
    ike-scan onesixtyone snmp \
    # traffic analysis
    tshark tcpflow ngrep \
    # tunneling
    sshuttle openvpn wireguard-tools \
    # QoL
    ripgrep fd-find fzf tree rsync bat proxychains4 openssh-client unzip zip procps tini tar \
    libplist-utils; \
  rm -rf /var/lib/apt/lists/*

# ---- Python network tooling ----
RUN python3 -m venv /opt/ghost-venv && \
    /opt/ghost-venv/bin/python -m pip install --upgrade pip "setuptools<81" wheel && \
    /opt/ghost-venv/bin/pip install --no-cache-dir \
      scapy impacket requests PySocks

# ---- Go tools (chisel + discovery) ----
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends golang-go; \
    export GOBIN=/usr/local/bin; \
    go install github.com/jpillora/chisel@latest; \
    go install github.com/projectdiscovery/dnsx/cmd/dnsx@latest; \
    go install github.com/projectdiscovery/httpx/cmd/httpx@latest; \
    apt-get purge -y --auto-remove golang-go; \
    rm -rf /root/go /home/*/go /var/lib/apt/lists/*

# ---- Network helper scripts ----
RUN set -eux; \
    printf '%s\n' '#!/usr/bin/env bash' \
    'set -euo pipefail' \
    'echo "[net] Quick Network Assessment:"' \
    'echo "  nmap -sC -sV -oA scan <target>"' \
    'echo "  masscan -p1-1000 <target> --rate=1000"' \
    'echo "  dnsx -d domain.com -a -aaaa -cname"' \
    'echo "  httpx -l hosts.txt -status-code"' \
    'echo "  ike-scan -A <target>"' \
    'echo "  onesixtyone <target>"' \
    > /usr/local/bin/gw-net-scan && chmod +x /usr/local/bin/gw-net-scan; \
    \
    printf '%s\n' '#!/usr/bin/env bash' \
    'set -euo pipefail' \
    'echo "[net] Tunneling & Pivoting:"' \
    'echo "  chisel server -p 8080 --reverse"' \
    'echo "  chisel client server:8080 R:1080:socks"' \
    'echo "  sshuttle -r user@jumpbox 10.0.0.0/8"' \
    'echo "  openvpn config.ovpn"' \
    'echo "  wg-quick up wg0.conf"' \
    'echo "  px nmap -sT target"' \
    > /usr/local/bin/gw-net-tunnel && chmod +x /usr/local/bin/gw-net-tunnel; \
    \
    printf '%s\n' '#!/usr/bin/env bash' \
    'set -euo pipefail' \
    'echo "[net] Traffic Analysis:"' \
    'echo "  tcpdump -i any -w capture.pcap"' \
    'echo "  tshark -r capture.pcap -Y \"http\""' \
    'echo "  tcpflow -r capture.pcap"' \
    'echo "  ngrep -d any -W byline port 80"' \
    > /usr/local/bin/gw-net-traffic && chmod +x /usr/local/bin/gw-net-traffic

# ---- Copy shared scripts ----
COPY scripts/px scripts/pxcurl scripts/session-log scripts/gw-versions \
     /usr/local/bin/

# ---- smoke test ----
COPY tests/smoke-test.sh /usr/local/bin/smoke-test

# ---- QoL: symlinks + prompt ----
RUN ln -s /usr/bin/fdfind /usr/local/bin/fd || true && \
    ln -s /usr/bin/batcat /usr/local/bin/bat || true && \
    cat > /etc/profile.d/ghostwire.sh <<'PSH' && chmod 0644 /etc/profile.d/ghostwire.sh
[ -n "$BASH_VERSION" ] || return 0
export ARTIFACTS=/shared
alias ll='ls -alF --color=auto'
alias bat='bat --paging=never'
alias fd='fdfind'
alias net-scan='gw-net-scan'
alias net-tunnel='gw-net-tunnel'
alias net-traffic='gw-net-traffic'
export HISTTIMEFORMAT="%F %T "
export HISTCONTROL=ignorespace:erasedups
GHOST_LABEL=${GHOST_LABEL:-network}
ghost_prompt(){ local r=$?; if [ $r -eq 0 ]; then GS="\[\e[1;32m\]✔"; else GS="\[\e[1;31m\]✘"; fi; export GS; }
PROMPT_COMMAND=ghost_prompt
PS1="\[\e[90m\][\A]\[\e[0m\] \[\e[1;34m\]ghostwire-net\[\e[0m\]\[\e[90m\]@\[\e[0m\]\[\e[90m\]${GHOST_LABEL}\[\e[0m\] \[\e[90m\](\w)\[\e[0m\]\n${GS}\[\e[90m\]>\[\e[0m\] "
if [ -n "${SOCKS5_HOST:-}" ]; then echo "[px] SOCKS5 target: ${SOCKS5_HOST}:${SOCKS5_PORT:-1080}"; fi
echo "[net] Tools: nmap, masscan, tshark, chisel, openvpn, wireguard, dnsx, httpx"
PSH

# ---- Non-root user ----
RUN groupadd -r ghost && useradd -m -g ghost -s /bin/bash ghost && \
    mkdir -p /work "${ARTIFACTS}" /opt/tools && \
    chown -R ghost:ghost /work "${ARTIFACTS}" /opt/tools /opt/ghost-venv && \
    printf 'ghost ALL=(ALL) NOPASSWD: /usr/sbin/tcpdump, /sbin/ip, /usr/bin/tshark\n' > /etc/sudoers.d/ghost && \
    chmod 0440 /etc/sudoers.d/ghost

USER ghost
WORKDIR /work
VOLUME ["/shared", "/work"]

HEALTHCHECK --interval=5m --timeout=10s --start-period=20s --retries=3 \
  CMD sh -c 'command -v nmap >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1 || exit 1'

STOPSIGNAL SIGINT
ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["/bin/bash"]
