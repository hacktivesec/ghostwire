# syntax=docker/dockerfile:1
ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.title="ghostwire-web" \
      org.opencontainers.image.description="Web application security: ffuf, gobuster, sqlmap, nikto, nuclei, httpx, wfuzz, wafw00f" \
      org.opencontainers.image.vendor="ghostwire" \
      org.opencontainers.image.version="dev" \
      org.opencontainers.image.licenses="CC0-1.0"

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PIP_NO_CACHE_DIR=1 \
    ARTIFACTS=/shared \
    SECLISTS=/opt/seclists \
    TERM=xterm-256color \
    SOCKS5_HOST=127.0.0.1 \
    SOCKS5_PORT=1080

# ---- Core OS packages ----
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      ca-certificates tzdata curl wget git unzip zip default-jre-headless \
      python3 python3-pip python3-venv sudo \
      nano less procps netcat-openbsd dnsutils nmap \
      nikto whatweb wafw00f wfuzz gobuster jq \
      proxychains4 openssh-client tini \
      ripgrep fd-find fzf bat tree rsync tar; \
    rm -rf /var/lib/apt/lists/*

# ---- SecLists ----
RUN set -eux; \
    git clone --depth=1 https://github.com/danielmiessler/SecLists "${SECLISTS}"; \
    rm -rf "${SECLISTS}/.git"

# ---- Python venv + web tools ----
RUN python3 -m venv /opt/ghost-venv && \
    /opt/ghost-venv/bin/python -m pip install --upgrade pip "setuptools<81" wheel && \
    /opt/ghost-venv/bin/pip install --no-cache-dir \
      sqlmap wafw00f arjun commix

# ---- XSStrike ----
RUN set -eux; \
    git clone --depth=1 https://github.com/s0md3v/XSStrike /opt/xsstrike; \
    /opt/ghost-venv/bin/pip install --no-cache-dir -r /opt/xsstrike/requirements.txt; \
    printf '#!/usr/bin/env bash\nexec /opt/ghost-venv/bin/python /opt/xsstrike/xsstrike.py "$@"\n' \
      > /usr/local/bin/xsstrike; \
    chmod +x /usr/local/bin/xsstrike

# ---- testssl.sh ----
RUN set -eux; \
    git clone --depth=1 https://github.com/drwetter/testssl.sh /opt/testssl; \
    ln -s /opt/testssl/testssl.sh /usr/local/bin/testssl; \
    chmod +x /usr/local/bin/testssl

# ---- Go web tools (each || true so one failure doesn't block the rest) ----
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends golang-go; \
    export GOBIN=/usr/local/bin; \
    go install github.com/ffuf/ffuf/v2@latest || true; \
    go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest || true; \
    go install github.com/projectdiscovery/httpx/cmd/httpx@latest || true; \
    go install github.com/projectdiscovery/dnsx/cmd/dnsx@latest || true; \
    go install github.com/projectdiscovery/katana/cmd/katana@latest || true; \
    go install github.com/tomnomnom/waybackurls@latest || true; \
    go install github.com/tomnomnom/gf@latest || true; \
    go install github.com/tomnomnom/unfurl@latest || true; \
    go install github.com/tomnomnom/qsreplace@latest || true; \
    go install github.com/jaeles-project/jaeles@latest || true; \
    go install github.com/jaeles-project/gospider@latest || true; \
    apt-get purge -y --auto-remove golang-go; \
    rm -rf /root/go /var/lib/apt/lists/*

# ---- PATH shims for venv tools ----
RUN set -eux; \
  for n in sqlmap wafw00f arjun commix; do \
    printf '%s\n' '#!/usr/bin/env bash' "exec /opt/ghost-venv/bin/${n} \"\$@\"" > "/usr/local/bin/${n}"; \
    chmod +x "/usr/local/bin/${n}"; \
  done

# ---- Copy shared scripts ----
COPY scripts/px scripts/pxcurl scripts/pxwget \
     scripts/savehere scripts/out scripts/session-log \
     scripts/update-seclists scripts/gw-versions \
     /usr/local/bin/

# ---- smoke test ----
COPY tests/smoke-test.sh /usr/local/bin/smoke-test

# ---- QoL profile ----
RUN ln -s /usr/bin/fdfind /usr/local/bin/fd || true && \
    ln -s /usr/bin/batcat /usr/local/bin/bat || true
COPY scripts/ghostwire-base.profile.sh /etc/profile.d/ghostwire-base.sh
COPY scripts/ghostwire-web.profile.sh /etc/profile.d/ghostwire-web.sh

# ---- Non-root user ----
RUN groupadd -r ghost && useradd -m -r -g ghost -s /bin/bash ghost && \
    mkdir -p /work "${ARTIFACTS}" /opt/tools && \
    chown -R ghost:ghost /work "${ARTIFACTS}" /opt/tools /opt/ghost-venv "${SECLISTS}" /opt/xsstrike /opt/testssl && \
    echo '. /etc/profile.d/ghostwire-web.sh' >> /home/ghost/.bashrc

USER ghost
WORKDIR /work
VOLUME ["/shared","/work"]

HEALTHCHECK --interval=5m --timeout=10s --start-period=20s --retries=3 \
  CMD sh -c 'command -v ffuf >/dev/null 2>&1 && command -v nuclei >/dev/null 2>&1 && command -v sqlmap >/dev/null 2>&1 || exit 1'

ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["/bin/bash"]
